extends layout

block content
  .row
    .col-12.col-md-9
      .page-header
        h1= location.name
      .row
        .col-12.col-md-6
          p.rating-stars
            - for (var i = 1; i <= location.rating; i++)
              i.fas.fa-star
            - for (var i = location.rating; i < 5; i++)
              i.far.fa-star
          p= location.address
          .card
            .card-body
              h2.h2 Opening hours
              each time in location.openingTimes
                p
                  | #{time.days} : 
                  if time.closed
                    | closed
                  else
                    | #{time.opening} - #{time.closing}
          .card
            .card-body
              h2.h2 Facilities
              each facility in location.facilities
                span.badge.badge-facility
                  i.fas.fa-check
                  | &nbsp;#{facility}
        .col-12.col-md-6
          .card
            .card-body
              h2.h2 Location map
              if location.coords
                iframe(width='100%', height='350', frameborder='0', scrolling='no', marginheight='0', marginwidth='0', src=`https://maps.google.com/maps?q=${location.coords.lat},${location.coords.lng}&z=15&output=embed`)
              else
                img.img-fluid.rounded(src='http://placehold.it/400x350?text=Map+Placeholder')
      
      .row
        .col-12
          .card
            .card-body
              .row
                .col-12.d-flex.justify-content-between.align-items-center
                  h2.section-title Customer reviews
                  a.btn.btn-review(href=`/location/review/new`) Add review
              
              each review in location.reviews
                .row.review
                  .col-12.no-gutters.review-header
                    span.rating-stars
                      - for (var i = 1; i <= review.rating; i++)
                        i.fas.fa-star
                      - for (var i = review.rating; i < 5; i++)
                        i.far.fa-star
                    span.reviewAuthor &nbsp;#{review.author}
                    small.reviewTimestamp &nbsp;#{review.timestamp}
                  .col-12
                    p= review.reviewText

    .col-12.col-md-3
      p.lead= location.description
      p= sidebar.callToAction
